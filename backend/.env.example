NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/logiflow

REDIS_URL=redis://localhost:6379

JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=7d

# Produção: origens permitidas (várias separadas por vírgula).
# Dev: ignorado para CORS — qualquer origem é refletida (use CORS_STRICT=1 para testar como produção).
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000
TRACKING_BASE_URL=http://localhost:3000/tracking

UPLOAD_DIR=./uploads
