{
  "name": "logiflow-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node --dns-result-order=ipv4first dist/server.js",
    "migrate": "node --dns-result-order=ipv4first ./node_modules/.bin/tsx src/shared/db/migrate.ts",
    "seed": "tsx src/shared/db/seed.ts",
    "reset": "tsx src/shared/db/reset.ts",
    "simulate": "tsx scripts/simulate-deliverer.ts",
    "fix-coords": "tsx scripts/fix-address-coords.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@hapi/boom": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.11",
    "@types/pg": "^8.11.6",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.18.1",
    "@whiskeysockets/baileys": "^6.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "ioredis": "^5.4.1",
    "nanoid": "^3.3.7",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "qrcode": "^1.5.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "zod": "^3.23.8"
  }
}
